@model IEnumerable<Colegio.BL.BE.Matricula>

@{
    ViewBag.Title = "Matrículas";
}

<h2 class="mb-3">Lista de Matrículas</h2>

<a href="@Url.Action("Create")" class="btn btn-success mb-3">+ Nueva Matrícula</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Alumno</th>
            <th>Fecha</th>
            <th>Periodo</th>
            <th style="width: 200px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var m in Model)
        {
            <tr>
                <td>@m.NombreAlumno</td>
                <td>@m.FechaMatricula.ToString("dd/MM/yyyy")</td>
                <td>@m.Periodo</td>
                <td>
                    <a href="@Url.Action("Details", new { id = m.IdMatricula })" class="btn btn-info btn-sm">Detalles</a>
                    <a href="@Url.Action("Delete", new { id = m.IdMatricula })" class="btn btn-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>
