@model Colegio.BL.BE.Matricula

@{
    ViewBag.Title = "Detalles de Matrícula";
}

<h2 class="mb-3">Detalles de Matrícula</h2>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5>Información de la Matrícula</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">ID Matrícula:</dt>
                    <dd class="col-sm-8">@Model.IdMatricula</dd>

                    <dt class="col-sm-4">Alumno:</dt>
                    <dd class="col-sm-8">@Model.NombreAlumno @Model.ApellidoAlumno</dd>

                    <dt class="col-sm-4">DNI:</dt>
                    <dd class="col-sm-8">@Model.DNIAlumno</dd>

                    <dt class="col-sm-4">Fecha Matrícula:</dt>
                    <dd class="col-sm-8">@Model.FechaMatricula.ToString("dd/MM/yyyy")</dd>

                    <dt class="col-sm-4">Período:</dt>
                    <dd class="col-sm-8">@Model.Periodo</dd>

                    <dt class="col-sm-4">Estado:</dt>
                    <dd class="col-sm-8">
                        <span class="badge @(Model.Estado == "Activa" ? "bg-success" : Model.Estado == "Anulada" ? "bg-danger" : Model.Estado == "Retirada" ? "bg-warning" : "bg-secondary")">
                            @Model.Estado
                        </span>
                        @if (Model.FechaEstado.HasValue)
                        {
                            <small class="text-muted">(@Model.FechaEstado.Value.ToString("dd/MM/yyyy"))</small>
                        }
                    </dd>

                    @if (!string.IsNullOrEmpty(Model.Observacion))
                    {
                        <dt class="col-sm-4">Observación:</dt>
                        <dd class="col-sm-8">@Model.Observacion</dd>
                    }
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5>Cursos Matriculados</h5>
            </div>
            <div class="card-body">
                @if (Model.Notas.Any())
                {
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Curso</th>
                                <th>Calificación</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var nota in Model.Notas)
                            {
                                <tr>
                                    <td>@nota.CursoNombre</td>
                                    <td>@nota.Calificacion</td>
                                    <td>
                                        @if (Model.Estado == "Activa")
                                        {
                                            <form method="post" action="@Url.Action("RetirarCurso", "Matricula")" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="idMatricula" value="@Model.IdMatricula" />
                                                <input type="hidden" name="idCurso" value="@nota.IdCurso" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                                        onclick="return confirm('¿Está seguro de retirar este curso?')">
                                                    Retirar
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">No hay cursos matriculados.</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5>Acciones de Gestión</h5>
            </div>
            <div class="card-body">
                @if (Model.Estado == "Activa")
                {
                    <div class="btn-group" role="group">
                        <form method="post" action="@Url.Action("Anular", "Matricula")" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.IdMatricula" />
                            <div class="mb-2">
                                <label>Observación para anular:</label>
                                <input type="text" name="observacion" class="form-control form-control-sm" placeholder="Motivo de anulación" />
                            </div>
                            <button type="submit" class="btn btn-danger btn-sm"
                                    onclick="return confirm('¿Está seguro de anular esta matrícula?')">
                                Anular Matrícula
                            </button>
                        </form>

                        <form method="post" action="@Url.Action("Retirar", "Matricula")" style="display:inline; margin-left: 10px;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.IdMatricula" />
                            <div class="mb-2">
                                <label>Observación para retirar:</label>
                                <input type="text" name="observacion" class="form-control form-control-sm" placeholder="Motivo de retiro" />
                            </div>
                            <button type="submit" class="btn btn-warning btn-sm"
                                    onclick="return confirm('¿Está seguro de retirar esta matrícula?')">
                                Retirar Matrícula
                            </button>
                        </form>

                        <form method="post" action="@Url.Action("Cancelar", "Matricula")" style="display:inline; margin-left: 10px;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.IdMatricula" />
                            <div class="mb-2">
                                <label>Observación para cancelar:</label>
                                <input type="text" name="form-control form-control-sm" placeholder="Motivo de cancelación" />
                            </div>
                            <button type="submit" class="btn btn-secondary btn-sm"
                                    onclick="return confirm('¿Está seguro de cancelar esta matrícula?')">
                                Cancelar Matrícula
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <p class="text-info">Esta matrícula ya no está activa (@Model.Estado)</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a href="@Url.Action("Index")" class="btn btn-secondary">Volver a la Lista</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}