@model Colegio.BL.BE.Matricula

@{
    ViewBag.Title = "Registrar Matrícula";
}

<h2 class="mb-3">Registrar Matrícula</h2>

@using (Html.BeginForm())
{
    @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

    <div class="form-group mb-3">
        <label>Alumno</label>
        @Html.DropDownListFor(m => m.IdAlumno, (IEnumerable<SelectListItem>)ViewBag.Alumnos,
        "-- Seleccione Alumno --", new { @class = "form-control" })
    @Html.ValidationMessageFor(m => m.IdAlumno)
</div>

<div class="form-group mb-3">
    @Html.LabelFor(m => m.FechaMatricula)
    @Html.TextBoxFor(m => m.FechaMatricula, "{0:yyyy-MM-dd}", new { type = "date", @class = "form-control" })
</div>

<div class="form-group mb-3">
    @Html.LabelFor(m => m.Periodo)
    @Html.TextBoxFor(m => m.Periodo, new { @class = "form-control" })
</div>

<div class="form-group mb-3">
    <label>Secciones a matricular</label>
    <div class="border rounded p-3" style="max-height: 320px; overflow-y: auto;">
        @foreach (var seccion in (IEnumerable<SelectListItem>)ViewBag.Secciones)
        {
            var seccionId = int.Parse(seccion.Value);
            var estaSeleccionado = Model?.SeccionesSeleccionadas?.Contains(seccionId) == true;
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="SeccionesSeleccionadas" value="@seccion.Value" id="seccion_@seccion.Value" @(estaSeleccionado ? "checked" : "") />
                <label class="form-check-label" for="seccion_@seccion.Value">@seccion.Text</label>
            </div>
        }
    </div>
    @Html.ValidationMessageFor(m => m.SeccionesSeleccionadas)
</div>

<button type="submit" class="btn btn-primary">Guardar Matrícula</button>
<a href="@Url.Action("Index")" class="btn btn-secondary">Cancelar</a>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
