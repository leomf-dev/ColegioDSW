@model Colegio.BL.BE.Curso

@{
    ViewBag.Title = "Nuevo Curso";
}

<h2 class="mb-3">Registrar Curso</h2>

@using (Html.BeginForm())
{
    @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

    <div class="form-group mb-3">
        @Html.LabelFor(m => m.Codigo)
        @Html.TextBoxFor(m => m.Codigo, new { @class = "form-control", placeholder = "ej. INF101" })
        @Html.ValidationMessageFor(m => m.Codigo)
    </div>

    <div class="form-group mb-3">
        @Html.LabelFor(m => m.Nombre)
        @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control", placeholder = "ej. Programación I" })
        @Html.ValidationMessageFor(m => m.Nombre)
    </div>

    <div class="form-group mb-3">
        @Html.LabelFor(m => m.Creditos)
        @Html.TextBoxFor(m => m.Creditos, new { @class = "form-control", type = "number", min = "1" })
        @Html.ValidationMessageFor(m => m.Creditos)
    </div>

    <div class="form-group mb-3">
        @Html.LabelFor(m => m.HorasSemanales)
        @Html.TextBoxFor(m => m.HorasSemanales, new { @class = "form-control", type = "number", min = "1" })
        @Html.ValidationMessageFor(m => m.HorasSemanales)
    </div>

    <div class="form-group mb-3">
        @Html.LabelFor(m => m.Estado)
        @Html.DropDownListFor(m => m.Estado, new SelectList(new[] { "Activo", "Inactivo" }), new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Estado)
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a href="@Url.Action("Index")" class="btn btn-secondary">Volver</a>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
