@model Colegio.BL.BE.SeccionBE

@{
    ViewBag.Title = "Detalles de la Sección";
}

<h2 class="mb-3">Detalles de la Sección</h2>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5>Información de la Sección</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">ID Sección:</dt>
                    <dd class="col-sm-8">@Model.IdSeccion</dd>

                    <dt class="col-sm-4">Código:</dt>
                    <dd class="col-sm-8">@Model.CodigoSeccion</dd>

                    <dt class="col-sm-4">Curso:</dt>
                    <dd class="col-sm-8">@Model.NombreCurso</dd>

                    <dt class="col-sm-4">Docente:</dt>
                    <dd class="col-sm-8">@Model.NombreDocente</dd>

                    <dt class="col-sm-4">Capacidad:</dt>
                    <dd class="col-sm-8">@Model.CapacidadMaxima</dd>

                    <dt class="col-sm-4">Estado:</dt>
                    <dd class="col-sm-8">
                        <span class="badge @(Model.Estado == "Activo" ? "bg-success" : "bg-secondary")">
                            @Model.Estado
                        </span>
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5>Horarios</h5>
            </div>
            <div class="card-body">
                @if (Model.Horarios.Any())
                {
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Día</th>
                                <th>Hora Inicio</th>
                                <th>Hora Fin</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var horario in Model.Horarios)
                            {
                                <tr>
                                    <td>@horario.Dia</td>
                                    <td>@horario.HoraInicio.ToString(@"hh\:mm")</td>
                                    <td>@horario.HoraFin.ToString(@"hh\:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">No hay horarios asignados.</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a href="@Url.Action("Edit", new { id = Model.IdSeccion })" class="btn btn-warning">Editar</a>
    <a href="@Url.Action("Index")" class="btn btn-secondary">Volver a la Lista</a>
</div>