@model Colegio.BL.BE.DocenteBE

@{
    ViewBag.Title = "Detalles del Docente";
}

<h2 class="mb-3">Detalles del Docente</h2>

<div class="card">
    <div class="card-header">
        <h5>Información del Docente</h5>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">ID Docente:</dt>
            <dd class="col-sm-8">@Model.IdDocente</dd>

            <dt class="col-sm-4">Nombres:</dt>
            <dd class="col-sm-8">@Model.Nombres</dd>

            <dt class="col-sm-4">Apellidos:</dt>
            <dd class="col-sm-8">@Model.Apellidos</dd>

            <dt class="col-sm-4">Especialidad:</dt>
            <dd class="col-sm-8">@Model.Especialidad</dd>

            <dt class="col-sm-4">Estado:</dt>
            <dd class="col-sm-8">
                <span class="badge @(Model.Estado == "Activo" ? "bg-success" : "bg-secondary")">
                    @Model.Estado
                </span>
            </dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a href="@Url.Action("Edit", new { id = Model.IdDocente })" class="btn btn-warning">Editar</a>
    <a href="@Url.Action("Index")" class="btn btn-secondary">Volver a la Lista</a>
</div>