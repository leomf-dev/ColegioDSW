@model Colegio.BL.BE.DocenteBE

@{
    ViewBag.Title = "Editar Docente";
}

<h2 class="mb-3">Editar Docente</h2>

@using (Html.BeginForm())
{
    @Html.HiddenFor(m => m.IdDocente)
    @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

    <div class="form-group mb-3">
        @Html.LabelFor(m => m.Nombres)
        @Html.TextBoxFor(m => m.Nombres, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Nombres)
    </div>

    <div class="form-group mb-3">
        @Html.LabelFor(m => m.Apellidos)
        @Html.TextBoxFor(m => m.Apellidos, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Apellidos)
    </div>

    <div class="form-group mb-3">
        @Html.LabelFor(m => m.Especialidad)
        @Html.TextBoxFor(m => m.Especialidad, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Especialidad)
    </div>

    <div class="form-group mb-3">
        @Html.LabelFor(m => m.Estado)
        @Html.DropDownListFor(m => m.Estado, new SelectList(new[] { "Activo", "Inactivo" }), new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Estado)
    </div>

    <button type="submit" class="btn btn-primary">Guardar Cambios</button>
    <a href="@Url.Action("Index")" class="btn btn-secondary">Cancelar</a>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}